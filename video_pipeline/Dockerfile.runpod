FROM runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04

WORKDIR /app

# Install dependencies only (model downloads at runtime on first request)
RUN pip install --no-cache-dir \
    diffusers transformers accelerate sentencepiece \
    protobuf ftfy opencv-python-headless runpod

ENV HF_HOME=/workspace/.cache/huggingface
RUN mkdir -p /workspace/.cache/huggingface /workspace/tmp

COPY video_pipeline/runpod_handler.py /app/handler.py

CMD ["python3", "-u", "/app/handler.py"]
